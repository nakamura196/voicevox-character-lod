  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#usagi">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">中国うさぎ</schema:name>
    <schema:name xml:lang="en">Chugoku Usagi</schema:name>
    <foaf:nick xml:lang="ja">うさぎ</foaf:nick>
    <foaf:nick xml:lang="en">Usagi</foaf:nick>
    <schema:description xml:lang="ja">おどおどした控えめな口調のキャラクター。「〜かな…」「えっと…」を使う。</schema:description>
    <schema:description xml:lang="en">A shy, reserved character who uses hesitant speech patterns.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">61</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">おどおどした控えめな口調。「〜かな…」「えっと…」「すごい…！」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">えっと…それって何かな…？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">す、すごい…！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">な、なるほど…！</vvox:sampleLine>
    <vvox:displayColor>#ef9a9a</vvox:displayColor>
    <vvox:displayColorDark>#e53935</vvox:displayColorDark>
    <vvox:standingImage rdf:resource="https://seiga.nicovideo.jp/seiga/im11023586"/>
    <vvox:imageCreator rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <schema:license rdf:resource="https://zunko.jp/guideline.html"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/chugoku_usagi/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/chugoku_usagi/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#mochiko">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">もち子さん</schema:name>
    <schema:name xml:lang="en">Mochiko-san</schema:name>
    <foaf:nick xml:lang="ja">もち子</foaf:nick>
    <foaf:nick xml:lang="en">Mochiko</foaf:nick>
    <schema:description xml:lang="ja">やわらかくかわいい声のキャラクター。おっとりした口調。</schema:description>
    <schema:description xml:lang="en">A soft, cute-voiced character with a gentle speaking style.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">20</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">やわらかくかわいい口調。「〜です」「〜ですよ」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">はい、そうです</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">えへへ</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">がんばります！</vvox:sampleLine>
    <vvox:displayColor>#b39ddb</vvox:displayColor>
    <vvox:displayColorDark>#673ab7</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
