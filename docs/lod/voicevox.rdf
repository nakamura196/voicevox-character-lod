  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#miko">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">櫻歌ミコ</schema:name>
    <schema:name xml:lang="en">Ouka Miko</schema:name>
    <foaf:nick xml:lang="ja">ミコ</foaf:nick>
    <foaf:nick xml:lang="en">Miko</foaf:nick>
    <schema:description xml:lang="ja">UTAU発のキャラクター。複数のフォーム（第二形態等）を持つ。</schema:description>
    <schema:description xml:lang="en">An UTAU-originated character with multiple forms.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">43</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">明るく元気な口調。「〜だよ！」「〜ね！」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">やっほー！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">それいいね！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">がんばるよ！</vvox:sampleLine>
    <vvox:displayColor>#ffab91</vvox:displayColor>
    <vvox:displayColorDark>#e64a19</vvox:displayColorDark>
