    <foaf:nick xml:lang="en">Itako</foaf:nick>
    <schema:description xml:lang="ja">東北応援キャラクター。落ち着いた大人の女性の口調。</schema:description>
    <schema:description xml:lang="en">A character supporting Tohoku region with a calm, mature female tone.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">109</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">落ち着いた大人の女性口調。「〜ですわ」「〜ですね」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">ええ、そうですわ</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">おもしろいですわね</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">なるほどですわ</vvox:sampleLine>
    <vvox:displayColor>#ce93d8</vvox:displayColor>
    <vvox:displayColorDark>#7b1fa2</vvox:displayColorDark>
