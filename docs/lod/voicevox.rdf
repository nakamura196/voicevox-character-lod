  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#zunko">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">東北ずん子</schema:name>
    <schema:name xml:lang="en">Tohoku Zunko</schema:name>
    <foaf:nick xml:lang="ja">ずん子</foaf:nick>
    <foaf:nick xml:lang="en">Zunko</foaf:nick>
    <schema:description xml:lang="ja">東北応援キャラクター。ずんだもんの姉的存在。明るく元気な口調。</schema:description>
    <schema:description xml:lang="en">A character supporting Tohoku region. An elder-sister figure to Zundamon with a bright, cheerful tone.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">107</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">明るく元気な口調。「〜だよ」「〜ね」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">えへへ、そうだよ！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">がんばろうね！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">楽しいね！</vvox:sampleLine>
    <vvox:displayColor>#81c784</vvox:displayColor>
    <vvox:displayColorDark>#2e7d32</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <schema:license rdf:resource="https://zunko.jp/guideline.html"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/tohoku_zunko/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/tohoku_zunko/"/>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q11526103"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#TTSEngine"/>
    <rdf:type rdf:resource="https://schema.org/SoftwareApplication"/>
    <schema:name xml:lang="ja">VOICEVOX</schema:name>
    <schema:name xml:lang="en">VOICEVOX</schema:name>
    <schema:description xml:lang="ja">無料で使えるテキスト読み上げ・歌声合成ソフトウェア。商用・非商用問わず利用可能。</schema:description>
    <schema:description xml:lang="en">Free text-to-speech and singing voice synthesis software. Available for both commercial and non-commercial use.</schema:description>
    <schema:url rdf:resource="https://voicevox.hiroshiba.jp/"/>
    <schema:license rdf:resource="https://github.com/VOICEVOX/voicevox/blob/main/LICENSE"/>
    <schema:author rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#hiroshiba"/>
    <schema:applicationCategory xml:lang="en">Multimedia</schema:applicationCategory>
    <schema:applicationCategory xml:lang="ja">マルチメディア</schema:applicationCategory>
    <schema:operatingSystem>Windows, macOS, Linux</schema:operatingSystem>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q106428182"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#itako">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
