    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#sora"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#pair_zundamon_metan">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#CharacterPair"/>
    <rdfs:label xml:lang="ja">ずんだもん × めたん</rdfs:label>
    <rdfs:label xml:lang="en">Zundamon x Metan</rdfs:label>
    <dcterms:description xml:lang="ja">定番ペア。ずんだもんが素朴に質問し、めたんが丁寧に解説。</dcterms:description>
    <dcterms:description xml:lang="en">Classic pair. Zundamon asks naive questions while Metan explains politely.</dcterms:description>
    <vvox:questioner rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#zundamon"/>
