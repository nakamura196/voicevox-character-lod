>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#maron">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">栗田まろん</schema:name>
    <schema:name xml:lang="en">Kurita Maron</schema:name>
    <foaf:nick xml:lang="ja">まろん</foaf:nick>
    <foaf:nick xml:lang="en">Maron</foaf:nick>
    <schema:description xml:lang="ja">おっとりした女性キャラクター。優しく丁寧な口調。</schema:description>
    <schema:description xml:lang="en">A gentle female character with a kind, polite speaking style.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">67</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">優しく丁寧な口調。「〜ですわ」「〜ですの」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">あら、そうですの</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">素敵ですわ</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">ごきげんよう</vvox:sampleLine>
    <vvox:displayColor>#bcaaa4</vvox:displayColor>
    <vvox:displayColorDark>#5d4037</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/kurita_maron/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/kurita_maron/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#pair_zunko_itako">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#CharacterPair"/>
    <rdfs:label xml:lang="ja">ずん子 × イタコ</rdfs:label>
    <rdfs:label xml:lang="en">Zunko x Itako</rdfs:label>
    <dcterms:description xml:lang="ja">東北姉妹。ずん子が元気に質問し、イタコが落ち着いて解説。</dcterms:description>
    <dcterms:description xml:lang="en">Tohoku sisters. Zunko asks cheerfully while Itako explains calmly.</dcterms:description>
    <vvox:questioner rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#zunko"/>
    <vvox:explainer rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#itako"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#zunko"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#itako"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#himari">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">冥鳴ひまり</schema:name>
    <schema:name xml:lang="en">Meimei Himari</schema:name>
    <foaf:nick xml:lang="ja">ひまり</foaf:nick>
    <foaf:nick xml:lang="en">Himari</foaf:nick>
    <schema:description xml:lang="ja">おっとりした癒し系の声のキャラクター。のんびりとした口調。</schema:description>
    <schema:description xml:lang="en">A soothing, gentle-voiced character with a relaxed speaking style.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">14</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">おっとりのんびりした口調。「〜だよ〜」「〜なの〜」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">うん、そうだよ〜</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">へぇ〜、おもしろいね〜</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">わかった〜</vvox:sampleLine>
    <vvox:displayColor>#f8bbd0</vvox:displayColor>
    <vvox:displayColorDark>#c2185b</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/meimei_himari/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/meimei_himari/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#ritsu">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">波音リツ</schema:name>
    <schema:name xml:lang="en">Namine Ritsu</schema:name>
    <foaf:nick xml:lang="ja">リツ</foaf:nick>
    <foaf:nick xml:lang="en">Ritsu</foaf:nick>
    <schema:description xml:lang="ja">力強くハスキーな声のキャラクター。UTAU発のキャラクターとしても有名。</schema:description>
    <schema:description xml:lang="en">A powerful, husky-voiced character. Also famous as an UTAU-originated character.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">9</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">力強くストレートな口調。はっきりした物言い</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">なるほどね</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">それでいいんじゃない？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">はっきり言うけどさ</vvox:sampleLine>
    <vvox:displayColor>#fff176</vvox:displayColor>
    <vvox:displayColorDark>#f9a825</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/namine_ritsu/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/namine_ritsu/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#sora">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">九州そら</schema:name>
    <schema:name xml:lang="en">Kyushu Sora</schema:name>
    <foaf:nick xml:lang="ja">そら</foaf:nick>
    <foaf:nick xml:lang="en">Sora</foaf:nick>
    <schema:description xml:lang="ja">おっとりした丁寧な口調のキャラクター。「〜ですね」「〜かしら」を使う。</schema:description>
    <schema:description xml:lang="en">A gentle character with a polite speaking style.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">16</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">おっとりした丁寧な口調。「〜ですね」「〜でしょう」「〜かしら」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">そうですね</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">〜ではないでしょうか</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">素敵ですね</vvox:sampleLine>
    <vvox:displayColor>#ea80fc</vvox:displayColor>
    <vvox:displayColorDark>#aa00ff</vvox:displayColorDark>
    <vvox:standingImage rdf:resource="https://seiga.nicovideo.jp/seiga/im10924061"/>
    <vvox:imageCreator rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <schema:license rdf:resource="https://zunko.jp/guideline.html"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/kyushu_sora/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/kyushu_sora/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#metan">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">四国めたん</schema:name>
    <schema:name xml:lang="en">Shikoku Metan</schema:name>
    <foaf:nick xml:lang="ja">めたん</foaf:nick>
    <foaf:nick xml:lang="en">Metan</foaf:nick>
    <schema:description xml:lang="ja">丁寧で分かりやすく説明するキャラクター。「〜よ」「〜わ」語尾が特徴。</schema:description>
    <schema:description xml:lang="en">A polite character who explains things clearly. Characterized by feminine speech patterns.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">「〜よ」「〜わ」語尾。丁寧で分かりやすく説明する</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">説明するわね</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">〜のよ</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">そのとおりよ！</vvox:sampleLine>
    <vvox:displayColor>#ff4081</vvox:displayColor>
    <vvox:displayColorDark>#c51162</vvox:displayColorDark>
    <vvox:standingImage rdf:resource="https://seiga.nicovideo.jp/seiga/im10849150"/>
    <vvox:imageCreator rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <schema:license rdf:resource="https://zunko.jp/guideline.html"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/shikoku_metan/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/shikoku_metan/"/>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q113476218"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#chibijii">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">ちび式じい</schema:name>
    <schema:name xml:lang="en">Chibishiki Jii</schema:name>
    <foaf:nick xml:lang="ja">ちび式じい</foaf:nick>
    <foaf:nick xml:lang="en">Chibi Jii</foaf:nick>
    <schema:description xml:lang="ja">おじいさんキャラクター。穏やかで味わい深い口調。</schema:description>
    <schema:description xml:lang="en">An elderly character with a gentle and flavorful speaking style.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">42</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">穏やかなおじいさん口調。「〜じゃのう」「〜かのう」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">ほっほっほ</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">なるほどのう</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">それはよいことじゃ</vvox:sampleLine>
    <vvox:displayColor>#d7ccc8</vvox:displayColor>
    <vvox:displayColorDark>#795548</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/chibishiki_jii/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/chibishiki_jii/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://twitter.com/sakamoto_ahr">
    <rdf:type rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
    <rdf:type rdf:resource="https://schema.org/Person"/>
    <schema:name xml:lang="ja">坂本アヒル</schema:name>
    <schema:name xml:lang="en">Sakamoto Ahiru</schema:name>
    <foaf:name xml:lang="ja">坂本アヒル</foaf:name>
    <foaf:homepage rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <schema:description xml:lang="ja">VOICEVOX公式キャラクターの立ち絵素材を制作</schema:description>
    <schema:description xml:lang="en">Creator of standing image illustrations for official VOICEVOX characters</schema:description>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#tsumugi">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">春日部つむぎ</schema:name>
    <schema:name xml:lang="en">Kasukabe Tsumugi</schema:name>
    <foaf:nick xml:lang="ja">つむぎ</foaf:nick>
    <foaf:nick xml:lang="en">Tsumugi</foaf:nick>
    <schema:description xml:lang="ja">明るくギャルっぽい口調のキャラクター。「〜じゃん」「マジ？」を多用。</schema:description>
    <schema:description xml:lang="en">A bright, gyaru-style character. Frequently uses casual expressions like 'Maji?' (Really?)</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">明るくギャルっぽい口調。「〜じゃん」「マジ？」「やばくない？」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">えー、マジ？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">それやばくない？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">なるほどね〜！</vvox:sampleLine>
    <vvox:displayColor>#ffab40</vvox:displayColor>
    <vvox:displayColorDark>#ff6d00</vvox:displayColorDark>
    <vvox:standingImage rdf:resource="https://seiga.nicovideo.jp/seiga/im10849150"/>
    <vvox:imageCreator rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <schema:license rdf:resource="https://tsumugi-official.studio.site/rule"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/kasukabe_tsumugi/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/kasukabe_tsumugi/"/>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q113476220"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#kouzakura">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">†聖騎士 紅桜†</schema:name>
    <schema:name xml:lang="en">Holy Knight Kouzakura</schema:name>
    <foaf:nick xml:lang="ja">紅桜</foaf:nick>
    <foaf:nick xml:lang="en">Kouzakura</foaf:nick>
    <schema:description xml:lang="ja">中二病風のキャラクター。大げさで芝居がかった口調。</schema:description>
    <schema:description xml:lang="en">A chuunibyou-style character with dramatic, theatrical speech.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">51</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">中二病風の大げさな口調。「〜であるぞ」「〜なのだ！」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">我が力を見よ！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">ふっ…面白い</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">これぞ真理…！</vvox:sampleLine>
    <vvox:displayColor>#ef5350</vvox:displayColor>
    <vvox:displayColorDark>#b71c1c</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/seikishi_kouzakura/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/seikishi_kouzakura/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#pair_tsumugi_kiritan">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#CharacterPair"/>
    <rdfs:label xml:lang="ja">つむぎ × きりたん</rdfs:label>
    <rdfs:label xml:lang="en">Tsumugi x Kiritan</rdfs:label>
    <dcterms:description xml:lang="ja">ギャル×クール。つむぎがカジュアルに質問し、きりたんが冷静に解説。</dcterms:description>
    <dcterms:description xml:lang="en">Gyaru x Cool. Tsumugi asks casually while Kiritan explains calmly.</dcterms:description>
    <vvox:questioner rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#tsumugi"/>
    <vvox:explainer rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#kiritan"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#tsumugi"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#kiritan"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#pair_kotaro_ryusei">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#CharacterPair"/>
    <rdfs:label xml:lang="ja">虎太郎 × 龍星</rdfs:label>
    <rdfs:label xml:lang="en">Kotaro x Ryusei</rdfs:label>
    <dcterms:description xml:lang="ja">少年×大人。虎太郎が元気に質問し、龍星が渋く解説。</dcterms:description>
    <dcterms:description xml:lang="en">Boy x Man. Kotaro asks energetically while Ryusei explains in a deep tone.</dcterms:description>
    <vvox:questioner rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#kotaro"/>
    <vvox:explainer rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#ryusei"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#kotaro"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#ryusei"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#kotaro">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">白上虎太郎</schema:name>
    <schema:name xml:lang="en">Shirakami Kotaro</schema:name>
    <foaf:nick xml:lang="ja">虎太郎</foaf:nick>
    <foaf:nick xml:lang="en">Kotaro</foaf:nick>
    <schema:description xml:lang="ja">元気いっぱいの少年キャラクター。明るく活発な口調。</schema:description>
    <schema:description xml:lang="en">An energetic boy character with a bright and lively tone.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">12</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">元気で活発な少年口調。「〜だよ！」「すげー！」「やった！」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">すげー！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">それってどういうこと？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">おもしれー！</vvox:sampleLine>
    <vvox:displayColor>#80deea</vvox:displayColor>
    <vvox:displayColorDark>#00838f</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/shirakami_kotaro/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/shirakami_kotaro/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#kiritan">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">東北きりたん</schema:name>
    <schema:name xml:lang="en">Tohoku Kiritan</schema:name>
    <foaf:nick xml:lang="ja">きりたん</foaf:nick>
    <foaf:nick xml:lang="en">Kiritan</foaf:nick>
    <schema:description xml:lang="ja">冷静でクールな口調のキャラクター。「つまり〜ということです」を使う。</schema:description>
    <schema:description xml:lang="en">A calm, cool character with a composed speaking style.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">108</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">冷静でクールな口調。「〜です」「〜ですね」「つまり〜ということです」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">そうですね</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">つまり〜ということです</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">理解しました</vvox:sampleLine>
    <vvox:displayColor>#ce93d8</vvox:displayColor>
    <vvox:displayColorDark>#ab47bc</vvox:displayColorDark>
    <vvox:standingImage rdf:resource="https://seiga.nicovideo.jp/seiga/im10849149"/>
    <vvox:imageCreator rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <schema:license rdf:resource="https://zunko.jp/guideline.html"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/tohoku_kiritan/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/tohoku_kiritan/"/>
