    <rdfs:label xml:lang="ja">うさぎ × そら</rdfs:label>
    <rdfs:label xml:lang="en">Usagi x Sora</rdfs:label>
    <dcterms:description xml:lang="ja">控えめ×おっとり。うさぎがおどおど質問し、そらが優しく解説。</dcterms:description>
    <dcterms:description xml:lang="en">Shy x Gentle. Usagi asks timidly while Sora explains kindly.</dcterms:description>
    <vvox:questioner rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#usagi"/>
