    <schema:name xml:lang="en">SAYO</schema:name>
    <foaf:nick xml:lang="ja">小夜</foaf:nick>
    <foaf:nick xml:lang="en">SAYO</foaf:nick>
    <schema:description xml:lang="ja">静かで落ち着いた声のキャラクター。ミステリアスな雰囲気。</schema:description>
    <schema:description xml:lang="en">A quiet, calm-voiced character with a mysterious atmosphere.</schema:description>
