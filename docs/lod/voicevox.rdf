    <vvox:sampleLine xml:lang="ja">そう…</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">不思議ね</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">なるほど…そういうこと</vvox:sampleLine>
    <vvox:displayColor>#e0e0e0</vvox:displayColor>
    <vvox:displayColorDark>#757575</vvox:displayColorDark>
