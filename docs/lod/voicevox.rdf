    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/mochiko/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#goki">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">後鬼</schema:name>
    <schema:name xml:lang="en">Goki</schema:name>
    <foaf:nick xml:lang="ja">後鬼</foaf:nick>
    <foaf:nick xml:lang="en">Goki</foaf:nick>
    <schema:description xml:lang="ja">鬼をモチーフにしたキャラクター。複数の人格スタイルを持つ。</schema:description>
    <schema:description xml:lang="en">An oni-themed character with multiple personality styles.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">27</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">落ち着いた口調と荒々しい口調を使い分ける</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">ふむ…</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">それで？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">わかった</vvox:sampleLine>
    <vvox:displayColor>#ffcc80</vvox:displayColor>
    <vvox:displayColorDark>#ef6c00</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/goki/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/goki/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#zundamon">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">ずんだもん</schema:name>
    <schema:name xml:lang="en">Zundamon</schema:name>
    <foaf:nick xml:lang="ja">ずんだもん</foaf:nick>
    <foaf:nick xml:lang="en">Zundamon</foaf:nick>
    <schema:description xml:lang="ja">好奇心旺盛で素朴な質問をするキャラクター。「〜のだ」「〜なのだ」語尾が特徴。</schema:description>
    <schema:description xml:lang="en">A curious character who asks naive questions. Characterized by the '~noda' speech pattern.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">「〜のだ」「〜なのだ」語尾。好奇心旺盛で素朴な質問をする</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">〜って何なのだ？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">へぇ〜！すごいのだ！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">なるほどなのだ！</vvox:sampleLine>
    <vvox:displayColor>#69f0ae</vvox:displayColor>
    <vvox:displayColorDark>#00c853</vvox:displayColorDark>
    <vvox:standingImage rdf:resource="https://seiga.nicovideo.jp/seiga/im10849148"/>
    <vvox:imageCreator rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <schema:license rdf:resource="https://zunko.jp/guideline.html"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/zundamon/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/zundamon/"/>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q113476219"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#pair_nekoaru_nekobii">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#CharacterPair"/>
    <rdfs:label xml:lang="ja">アル × ビィ</rdfs:label>
    <rdfs:label xml:lang="en">Aru x Bii</rdfs:label>
    <dcterms:description xml:lang="ja">猫使ペア。アルが気まぐれに質問し、ビィが控えめに解説。</dcterms:description>
    <dcterms:description xml:lang="en">Cat-user pair. Aru asks capriciously while Bii explains quietly.</dcterms:description>
    <vvox:questioner rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#nekoaru"/>
    <vvox:explainer rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#nekobii"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#nekoaru"/>
    <vvox:hasMember rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#nekobii"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#no7">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">No.7</schema:name>
    <schema:name xml:lang="en">No.7</schema:name>
    <foaf:nick xml:lang="ja">No.7</foaf:nick>
    <foaf:nick xml:lang="en">No.7</foaf:nick>
    <schema:description xml:lang="ja">ロボット風の無機質な声のキャラクター。アナウンス・読み上げスタイルを持つ。</schema:description>
    <schema:description xml:lang="en">A robotic, inorganic-voiced character with announcement and reading styles.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">29</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">無機質で淡々とした口調。「〜です」「〜ます」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">了解しました</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">報告します</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">データを確認します</vvox:sampleLine>
    <vvox:displayColor>#b0bec5</vvox:displayColor>
    <vvox:displayColorDark>#607d8b</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/no7/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/no7/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#hau">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">雨晴はう</schema:name>
    <schema:name xml:lang="en">Amehare Hau</schema:name>
    <foaf:nick xml:lang="ja">はう</foaf:nick>
    <foaf:nick xml:lang="en">Hau</foaf:nick>
    <schema:description xml:lang="ja">元気でハキハキした口調のキャラクター。看護学生。</schema:description>
    <schema:description xml:lang="en">An energetic character with a lively speaking style. A nursing student.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">10</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">元気でハキハキした口調。「〜だよ！」「えっと〜」「がんばろう！」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">えっと、それって何？</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">わぁ、すごいね！</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">なるほど〜！</vvox:sampleLine>
    <vvox:displayColor>#4dd0e1</vvox:displayColor>
    <vvox:displayColorDark>#00acc1</vvox:displayColorDark>
    <vvox:standingImage rdf:resource="https://seiga.nicovideo.jp/seiga/im10913655"/>
    <vvox:imageCreator rdf:resource="https://twitter.com/sakamoto_ahr"/>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/amehare_hau/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/amehare_hau/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#nurserobot">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">ナースロボ＿タイプT</schema:name>
    <schema:name xml:lang="en">Nurse Robot Type T</schema:name>
    <foaf:nick xml:lang="ja">ナースロボ</foaf:nick>
    <foaf:nick xml:lang="en">Nurse Robot</foaf:nick>
    <schema:description xml:lang="ja">ナースロボットのキャラクター。丁寧で機械的な口調。</schema:description>
    <schema:description xml:lang="en">A nurse robot character with a polite, mechanical speaking style.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">47</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">丁寧で機械的な口調。「〜です」「〜ですね」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">お体の調子はいかがですか</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">了解しました</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">ご説明いたします</vvox:sampleLine>
    <vvox:displayColor>#e6ee9c</vvox:displayColor>
    <vvox:displayColorDark>#9e9d24</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/nurse_robot_type_t/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/nurse_robot_type_t/"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#takehiro">
    <rdf:type rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#Character"/>
    <schema:name xml:lang="ja">玄野武宏</schema:name>
    <schema:name xml:lang="en">Genno Takehiro</schema:name>
    <foaf:nick xml:lang="ja">武宏</foaf:nick>
    <foaf:nick xml:lang="en">Takehiro</foaf:nick>
    <schema:description xml:lang="ja">落ち着いた青年の声のキャラクター。サラリーマン風の丁寧な口調。</schema:description>
    <schema:description xml:lang="en">A calm young man's voice character with a polite, business-like tone.</schema:description>
    <vvox:speakerId rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">11</vvox:speakerId>
    <vvox:speechStyle xml:lang="ja">落ち着いた丁寧な男性口調。「〜ですね」「〜でしょうか」を使う</vvox:speechStyle>
    <vvox:sampleLine xml:lang="ja">なるほど、そういうことですか</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">確かにそうですね</vvox:sampleLine>
    <vvox:sampleLine xml:lang="ja">説明しましょう</vvox:sampleLine>
    <vvox:displayColor>#a5d6a7</vvox:displayColor>
    <vvox:displayColorDark>#388e3c</vvox:displayColorDark>
    <vvox:hasEngine rdf:resource="https://nakamura196.github.io/voicevox-character-lod/ns/voicevox#voicevox"/>
    <foaf:homepage rdf:resource="https://voicevox.hiroshiba.jp/product/genno_takehiro/"/>
    <schema:image rdf:resource="https://voicevox.hiroshiba.jp/product/genno_takehiro/"/>
  </rdf:Description>
