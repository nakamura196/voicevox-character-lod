# ---------------------------------------------------------------------------
# Character Pairs
# ---------------------------------------------------------------------------

vvox:pair_zundamon_metan a vvox:CharacterPair ;
    rdfs:label "ずんだもん × めたん"@ja , "Zundamon x Metan"@en ;
    dcterms:description
        "定番ペア。ずんだもんが素朴に質問し、めたんが丁寧に解説。"@ja ,
        "Classic pair. Zundamon asks naive questions while Metan explains politely."@en ;
    vvox:questioner vvox:zundamon ;
    vvox:explainer  vvox:metan ;
    vvox:hasMember  vvox:zundamon , vvox:metan .

vvox:pair_tsumugi_kiritan a vvox:CharacterPair ;
    rdfs:label "つむぎ × きりたん"@ja , "Tsumugi x Kiritan"@en ;
    dcterms:description
        "ギャル×クール。つむぎがカジュアルに質問し、きりたんが冷静に解説。"@ja ,
        "Gyaru x Cool. Tsumugi asks casually while Kiritan explains calmly."@en ;
    vvox:questioner vvox:tsumugi ;
    vvox:explainer  vvox:kiritan ;
    vvox:hasMember  vvox:tsumugi , vvox:kiritan .

vvox:pair_usagi_sora a vvox:CharacterPair ;
    rdfs:label "うさぎ × そら"@ja , "Usagi x Sora"@en ;
    dcterms:description
        "控えめ×おっとり。うさぎがおどおど質問し、そらが優しく解説。"@ja ,
        "Shy x Gentle. Usagi asks timidly while Sora explains kindly."@en ;
    vvox:questioner vvox:usagi ;
    vvox:explainer  vvox:sora ;
    vvox:hasMember  vvox:usagi , vvox:sora .

vvox:pair_hau_whitecul a vvox:CharacterPair ;
    rdfs:label "はう × WhiteCUL"@ja , "Hau x WhiteCUL"@en ;
    dcterms:description
        "元気ナース×知的。はうがハキハキ質問し、WhiteCULが知的に解説。"@ja ,
        "Energetic x Intellectual. Hau asks briskly while WhiteCUL explains thoughtfully."@en ;
    vvox:questioner vvox:hau ;
    vvox:explainer  vvox:whitecul ;
    vvox:hasMember  vvox:hau , vvox:whitecul .
