vvox:usagi a vvox:Character ;
    schema:name "中国うさぎ"@ja , "Chugoku Usagi"@en ;
    foaf:nick "うさぎ"@ja , "Usagi"@en ;
    schema:description
        "おどおどした控えめな口調のキャラクター。「〜かな…」「えっと…」を使う。"@ja ,
