    vvox:sampleLine "そうですね"@ja , "〜ではないでしょうか"@ja , "素敵ですね"@ja ;
    vvox:displayColor "#ea80fc" ;
    vvox:displayColorDark "#aa00ff" ;
    vvox:standingImage <https://seiga.nicovideo.jp/seiga/im10924061> ;
