# ---------------------------------------------------------------------------
# Dataset Metadata (inline)
# ---------------------------------------------------------------------------

<https://nakamura196.github.io/voicevox-character-lod/lod/voicevox>
    a schema:Dataset ;
    schema:name "VOICEVOX Character LOD"@en ,
                "VOICEVOX キャラクター LOD"@ja ;
    schema:description
        "Linked Open Data dataset describing characters, speech styles, and dialogue pairs of the VOICEVOX text-to-speech engine."@en ,
        "VOICEVOXテキスト音声合成エンジンのキャラクター・口調・対話ペアを記述するLinked Open Dataデータセット。"@ja ;
    schema:license <https://creativecommons.org/licenses/by/4.0/> ;
    schema:creator <https://github.com/nakamura196> ;
    schema:dateCreated "2026-03-10"^^xsd:date ;
    schema:dateModified "2026-03-10"^^xsd:date ;
    schema:url <https://nakamura196.github.io/voicevox-character-lod/> ;
    schema:isBasedOn <https://voicevox.hiroshiba.jp/> .

# ---------------------------------------------------------------------------
# TTS Engine
# ---------------------------------------------------------------------------

vvox:voicevox a vvox:TTSEngine , schema:SoftwareApplication ;
    schema:name "VOICEVOX"@ja , "VOICEVOX"@en ;
    schema:description
        "無料で使えるテキスト読み上げ・歌声合成ソフトウェア。商用・非商用問わず利用可能。"@ja ,
        "Free text-to-speech and singing voice synthesis software. Available for both commercial and non-commercial use."@en ;
    schema:url <https://voicevox.hiroshiba.jp/> ;
    schema:license <https://github.com/VOICEVOX/voicevox/blob/main/LICENSE> ;
    schema:author vvox:hiroshiba ;
    schema:applicationCategory "Multimedia"@en , "マルチメディア"@ja ;
    schema:operatingSystem "Windows, macOS, Linux" ;
    owl:sameAs wd:Q106428182 ;
    foaf:homepage <https://voicevox.hiroshiba.jp/> .

# ---------------------------------------------------------------------------
# Persons
# ---------------------------------------------------------------------------

vvox:hiroshiba a foaf:Person , schema:Person ;
    schema:name "ヒホ（廣芝和之）"@ja , "Hiho (Kazuyuki Hiroshiba)"@en ;
    foaf:name "ヒホ"@ja ;
    foaf:homepage <https://hiroshiba.jp/> ;
    owl:sameAs <https://github.com/Hiroshiba> .

<https://twitter.com/sakamoto_ahr> a foaf:Person , schema:Person ;
    schema:name "坂本アヒル"@ja , "Sakamoto Ahiru"@en ;
    foaf:name "坂本アヒル"@ja ;
    foaf:homepage <https://twitter.com/sakamoto_ahr> ;
    schema:description "VOICEVOX公式キャラクターの立ち絵素材を制作"@ja ,
                       "Creator of standing image illustrations for official VOICEVOX characters"@en .

# ---------------------------------------------------------------------------
# Characters
# ---------------------------------------------------------------------------

vvox:zundamon a vvox:Character ;
    schema:name "ずんだもん"@ja , "Zundamon"@en ;
    foaf:nick "ずんだもん"@ja , "Zundamon"@en ;
    schema:description
        "好奇心旺盛で素朴な質問をするキャラクター。「〜のだ」「〜なのだ」語尾が特徴。"@ja ,
        "A curious character who asks naive questions. Characterized by the '~noda' speech pattern."@en ;
    vvox:speakerId 3 ;
    vvox:speechStyle "「〜のだ」「〜なのだ」語尾。好奇心旺盛で素朴な質問をする"@ja ;
    vvox:sampleLine "〜って何なのだ？"@ja , "へぇ〜！すごいのだ！"@ja , "なるほどなのだ！"@ja ;
    vvox:displayColor "#69f0ae" ;
    vvox:displayColorDark "#00c853" ;
    vvox:standingImage <https://seiga.nicovideo.jp/seiga/im10849148> ;
    vvox:imageCreator <https://twitter.com/sakamoto_ahr> ;
    vvox:hasEngine vvox:voicevox ;
    schema:license <https://zunko.jp/guideline.html> ;
    foaf:homepage <https://voicevox.hiroshiba.jp/product/zundamon/> ;
    schema:image <https://voicevox.hiroshiba.jp/product/zundamon/> ;
    owl:sameAs wd:Q113476219 .

vvox:metan a vvox:Character ;
    schema:name "四国めたん"@ja , "Shikoku Metan"@en ;
    foaf:nick "めたん"@ja , "Metan"@en ;
    schema:description
        "丁寧で分かりやすく説明するキャラクター。「〜よ」「〜わ」語尾が特徴。"@ja ,
        "A polite character who explains things clearly. Characterized by feminine speech patterns."@en ;
    vvox:speakerId 2 ;
    vvox:speechStyle "「〜よ」「〜わ」語尾。丁寧で分かりやすく説明する"@ja ;
    vvox:sampleLine "説明するわね"@ja , "〜のよ"@ja , "そのとおりよ！"@ja ;
    vvox:displayColor "#ff4081" ;
    vvox:displayColorDark "#c51162" ;
    vvox:standingImage <https://seiga.nicovideo.jp/seiga/im10849150> ;
    vvox:imageCreator <https://twitter.com/sakamoto_ahr> ;
    vvox:hasEngine vvox:voicevox ;
    schema:license <https://zunko.jp/guideline.html> ;
    foaf:homepage <https://voicevox.hiroshiba.jp/product/shikoku_metan/> ;
    schema:image <https://voicevox.hiroshiba.jp/product/shikoku_metan/> ;
    owl:sameAs wd:Q113476218 .

vvox:tsumugi a vvox:Character ;
    schema:name "春日部つむぎ"@ja , "Kasukabe Tsumugi"@en ;
    foaf:nick "つむぎ"@ja , "Tsumugi"@en ;
    schema:description
        "明るくギャルっぽい口調のキャラクター。「〜じゃん」「マジ？」を多用。"@ja ,
        "A bright, gyaru-style character. Frequently uses casual expressions like 'Maji?' (Really?)"@en ;
    vvox:speakerId 8 ;
    vvox:speechStyle "明るくギャルっぽい口調。「〜じゃん」「マジ？」「やばくない？」を使う"@ja ;
    vvox:sampleLine "えー、マジ？"@ja , "それやばくない？"@ja , "なるほどね〜！"@ja ;
    vvox:displayColor "#ffab40" ;
    vvox:displayColorDark "#ff6d00" ;
    vvox:standingImage <https://seiga.nicovideo.jp/seiga/im10849150> ;
    vvox:imageCreator <https://twitter.com/sakamoto_ahr> ;
    vvox:hasEngine vvox:voicevox ;
    schema:license <https://tsumugi-official.studio.site/rule> ;
    foaf:homepage <https://voicevox.hiroshiba.jp/product/kasukabe_tsumugi/> ;
    schema:image <https://voicevox.hiroshiba.jp/product/kasukabe_tsumugi/> ;
    owl:sameAs wd:Q113476220 .

vvox:hau a vvox:Character ;
    schema:name "雨晴はう"@ja , "Amehare Hau"@en ;
    foaf:nick "はう"@ja , "Hau"@en ;
    schema:description
        "元気でハキハキした口調のキャラクター。看護学生。"@ja ,
        "An energetic character with a lively speaking style. A nursing student."@en ;
    vvox:speakerId 10 ;
    vvox:speechStyle "元気でハキハキした口調。「〜だよ！」「えっと〜」「がんばろう！」を使う"@ja ;
    vvox:sampleLine "えっと、それって何？"@ja , "わぁ、すごいね！"@ja , "なるほど〜！"@ja ;
    vvox:displayColor "#4dd0e1" ;
    vvox:displayColorDark "#00acc1" ;
    vvox:standingImage <https://seiga.nicovideo.jp/seiga/im10913655> ;
    vvox:imageCreator <https://twitter.com/sakamoto_ahr> ;
    vvox:hasEngine vvox:voicevox ;
    foaf:homepage <https://voicevox.hiroshiba.jp/product/amehare_hau/> ;
    schema:image <https://voicevox.hiroshiba.jp/product/amehare_hau/> .

